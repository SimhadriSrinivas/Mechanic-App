{
  "name": "frontend",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "optimize:images": "node compress-images.js",
    "analyze:deps": "depcheck --skip-missing=true --ignores=expo-splash-screen,react-native-worklets,babel-plugin-transform-remove-console,expo-module-scripts,typescript",
    "build:apk:min": "cd android && gradlew.bat clean assembleRelease -PreactNativeArchitectures=arm64-v8a,armeabi-v7a"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "appwrite": "^21.5.0",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.12",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.11",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-keep-awake": "^55.0.4",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
